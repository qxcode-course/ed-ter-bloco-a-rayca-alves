            "content": "package main\n\nimport \"fmt\"\n\nfunc print(fila []int, pos int) {\n\tfmt.Print(\"[ \")\n\tfor i := 0; i < len(fila); i++ {\n\t\tif i == pos {\n\t\t\tfmt.Printf(\"%d> \", fila[i])\n\t\t} else {\n\t\t\tfmt.Printf(\"%d \", fila[i])\n\t\t}\n\t}\n\tfmt.Println(\"]\")\n}\n\nfunc main() {\n\tvar n, e int\n\tfmt.Scan(&n, &e)\n\n\tfila := make([]int, n)\n\tfor i := 0; i < n; i++ {\n\t\tfila[i] = i + 1\n\t}\n\n\tmortos := make(map[int]bool)\n\tpos := e - 1\n\n\tfor len(fila) > 1 {\n\t\tprint(fila, pos)\n\n\t\tmorto := (pos + 1) % len(fila)\n\t\tmortos[fila[morto]] = true\n\n\t\tnova := []int{}\n\t\tfor _, p := range fila {\n\t\t\tif !mortos[p] {\n\t\t\t\tnova = append(nova, p)\n\t\t\t}\n\t\t}\n\n        if morto > pos {\n\t\t\tpos = (pos + 1) % len(nova)\n\t\t} else {\n\t\t\tpos = pos % len(nova)\n\t\t}\n\n\t\tfila = nova\n\t}\n\n\t\n\tprint(fila, pos)\n}",
